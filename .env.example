NODE_ENV=dev
PORT=3303
SCANNER_CRON=*/10 * * * *

# Database Connection (Node.js)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=grn-db
DB_POOL_MIN=2
DB_POOL_MAX=10

# Database Initialization (Docker Compose only)
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=grn-db

GITHUB_TOKEN=your_github_token_here

# Email Service (SMTP)
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="GitHub Notifier" <noreply@notifier.local>