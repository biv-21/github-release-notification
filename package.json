    "migrate:up": "node scripts/migrate.js up",
    "migrate:down": "node scripts/migrate.js down",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@octokit/core": "7.0.6",
    "@octokit/plugin-throttling": "11.0.3",
    "dotenv": "17.4.1",
    "express": "5.2.1",
    "node-cron": "4.2.1",
    "node-pg-migrate": "8.0.4",
    "nodemailer": "8.0.5",
    "octokit": "5.0.5",
    "pg": "8.20.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "jest": "^30.3.0"
  }
}
